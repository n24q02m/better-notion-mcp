{
  "name": "@n24q02m/better-notion-mcp",
  "mcpName": "io.github.n24q02m/better-notion-mcp",
  "keywords": [
    "notion",
    "api",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "composite-tools",
    "claude",
    "cursor",
    "copilot",
    "antigravity",
    "codex",
    "opencode",
    "gemini-cli"
  ],
  "version": "2.13.1",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.2.21",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -build && node scripts/build-cli.js",
    "dev": "tsx watch scripts/start-server.ts",
    "test": "vitest --passWithNoTests",
    "test:watch": "vitest watch",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit",
    "check": "biome check . && bun run type-check",
    "check:fix": "biome check --write . && bun run type-check",
    "prepublishOnly": "bun run build",
    "docker:build": "docker build -t n24q02m/better-notion-mcp:latest .",
    "docker:push": "docker push n24q02m/better-notion-mcp:latest",
    "docker:run": "docker run --rm -i -e NOTION_TOKEN n24q02m/better-notion-mcp:latest"
  },
  "bin": {
    "better-notion-mcp": "bin/cli.mjs"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "build/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@notionhq/client": "^5.11.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "description": "Better MCP server for Notion API with composite tools optimized for AI agents",
  "main": "build/src/init-server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/n24q02m/better-notion-mcp.git"
  },
  "author": "n24q02m",
  "bugs": {
    "url": "https://github.com/n24q02m/better-notion-mcp/issues"
  },
  "homepage": "https://github.com/n24q02m/better-notion-mcp#readme"
}
